            </div>
        </section>
        <!-- DFA Live Debugger Console -->
        <section class="console-panel">
            <div class="console-header">
                <div class="console-title">Automata State Transition Console</div>
                <button type="button" class="btn-secondary" style="padding: 0.25rem 0.6rem; font-size: 0.75rem; border-radius: 4px;" onclick="clearConsole()">Clear Logs</button>
            </div>
            <div id="consoleBody" class="console-body">
                <div class="console-line info">[System] Welcome. Select a sample resume or paste details, then click "Parse CV Profile" to trace state machine transitions.</div>
            </div>
        </section>
    </main>
    <!-- Scripting Area -->
    <script>
        // =====================================================================
        // 1. DFA IMPLEMENTATIONS
        // =====================================================================
        class EmailDFA {
            constructor() { this.reset(); }
            reset() {
                this.state = "START";
                this.history = [];
            }
            transition(char) {
                const prev = this.state;
                const isAlphanumeric = /[a-zA-Z0-9]/.test(char);
                const isAlpha = /[a-zA-Z]/.test(char);
                const isLocalSymbol = /[._%+-]/.test(char);
                if (this.state === "START") {
                    if (isAlphanumeric || isLocalSymbol) this.state = "LOCAL_PART";
                    else this.state = "INVALID";
                } else if (this.state === "LOCAL_PART") {
                    if (char === '@') this.state = "AT_SYMBOL";
                    else if (isAlphanumeric || isLocalSymbol) this.state = "LOCAL_PART";
                    else this.state = "INVALID";
                } else if (this.state === "AT_SYMBOL") {
                    if (isAlphanumeric || char === '-') this.state = "DOMAIN";
                    else this.state = "INVALID";
                } else if (this.state === "DOMAIN") {
                    if (char === '.') this.state = "DOT";
                    else if (isAlphanumeric || char === '-') this.state = "DOMAIN";
                    else this.state = "INVALID";
                } else if (this.state === "DOT") {
                    if (isAlpha) this.state = "TLD";
                    else this.state = "INVALID";
                } else if (this.state === "TLD") {
                    if (isAlpha) this.state = "TLD";
                    else if (char === '.') this.state = "DOT";
                    else this.state = "INVALID";
                } else {
                    this.state = "INVALID";
                }
                this.history.push({ prev, char, current: this.state });
                return this.state;
            }
            isAccepted() { return this.state === "TLD"; }
            validate(str) {
                this.reset();
                for (let c of str) {
                    this.transition(c);
                    if (this.state === "INVALID") return false;
                }
                return this.isAccepted();
            }
        }
        class PakistaniPhoneDFA {
            constructor() { this.reset(); }
            reset() {
                this.state = "START";
                this.history = [];
            }
            transition(char) {
                const prev = this.state;
                const isDigit = /[0-9]/.test(char);
                if (this.state === "START") {
                    if (char === '+') this.state = "PLUS_DETECTED";
                    else if (char === '0') this.state = "ZERO_DETECTED";
                    else this.state = "INVALID";
                } else if (this.state === "PLUS_DETECTED") {
                    this.state = (char === '9') ? "NINE_DETECTED" : "INVALID";
                } else if (this.state === "NINE_DETECTED") {
                    this.state = (char === '2') ? "TWO_DETECTED" : "INVALID";
                } else if (this.state === "TWO_DETECTED" || this.state === "TWO_SEP_DETECTED") {
                    if (char === ' ' || char === '-') this.state = "TWO_SEP_DETECTED";
                    else if (char === '3') this.state = "THREE_DETECTED";
                    else if (char === '2') this.state = "LANDLINE_CITY_2";
                    else if (char === '4') this.state = "LANDLINE_CITY_4";
              
