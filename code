            </div>
            <div>
                <h3 style="font-size: 1rem; font-weight: 600; margin-bottom: 0.75rem; color: var(--accent-teal);">Education History</h3>
                <div class="table-container">
                    <table id="educationTable">
                        <thead>
                            <tr>
                                <th>Degree</th>
                                <th>Field/Major</th>
                                <th>University</th>
                                <th>Graduation Year</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td colspan="4" style="text-align: center; color: var(--text-muted); font-style: italic;">No records extracted</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
            <div>
                <h3 style="font-size: 1rem; font-weight: 600; margin-bottom: 0.75rem; color: var(--accent-teal);">Work Experience</h3>
